# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored so your keys never get uploaded.

# MapTiler (free) — https://cloud.maptiler.com -> API Keys
NEXT_PUBLIC_MAPTILER_KEY=

# Supabase (Phase 2) — https://supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. NEVER expose this in the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for ingestion scripts (server-side only).
# Supabase -> Connect -> Session pooler URI, with your database password.
SUPABASE_DB_URL=
